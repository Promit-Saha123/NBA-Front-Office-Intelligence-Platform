# Placeholder variable names only — no real values. Copy to .env and fill locally.
# .env is gitignored; never commit real credentials.

# PostgreSQL connection for the backend
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME

# PostgreSQL container settings (used by docker-compose.yml)
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=nba_platform

# Comma-separated origins allowed to call the FastAPI backend's CORS-protected
# routes from a browser (backend/api/app.py). Defaults to the Next.js dev
# server's origin if unset.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

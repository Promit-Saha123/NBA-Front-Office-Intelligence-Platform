# Placeholder variable names only — no real values. Copy to .env and fill locally.
# .env is gitignored; never commit real credentials.

# PostgreSQL connection for the backend
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME

# PostgreSQL container settings (used by docker-compose.yml)
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=nba_platform

# Comma-separated origins allowed to call the FastAPI backend's CORS-protected
# routes from a browser (backend/api/app.py, parsed by _frontend_origins()).
# Defaults to the Next.js dev server's origins if unset — no wildcard is ever
# used. Read once at process startup; restart the backend after changing this.
#
# Local development (the default below matches `pnpm dev`'s port):
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#
# Future public deployment (illustrative only — no hosting is provisioned yet,
# see HANDOFF.md's "Portfolio Roadmap"): set this to the real Vercel origin,
# e.g. FRONTEND_ORIGINS=https://your-project.vercel.app
